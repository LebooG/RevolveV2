# ──────────────────────────────────────────────
# REVOLVE RENT — Environment Configuration
# ──────────────────────────────────────────────

# ╔══════════════════════════════════════════════════════════════╗
# ║              WHERE TO GET YOUR API KEYS                      ║
# ╠══════════════════════════════════════════════════════════════╣
# ║                                                              ║
# ║  M-PESA (Safaricom Daraja)                                  ║
# ║  ──────────────────────────                                  ║
# ║  1. Go to https://developer.safaricom.co.ke                 ║
# ║  2. Sign up / Log in                                        ║
# ║  3. Click "Add a New App" → select Lipa Na M-Pesa           ║
# ║  4. Consumer Key & Secret are on the app page (Keys tab)    ║
# ║  5. Passkey: sandbox default for testing; request production ║
# ║     passkey from Safaricom after Go-Live review              ║
# ║  6. Shortcode: 174379 (sandbox) or your registered Paybill  ║
# ║  7. Callback URL: must be publicly accessible (use ngrok    ║
# ║     for local dev: ngrok http 3000)                         ║
# ║                                                              ║
# ║  HOSTPINNACLE SMS                                            ║
# ║  ─────────────────                                           ║
# ║  1. Go to https://smsportal.hostpinnacle.co.ke              ║
# ║  2. Sign up / Log in                                        ║
# ║  3. USER_ID = your login username                           ║
# ║  4. PASSWORD = your login password                          ║
# ║  5. Register Sender ID under "Sender ID Management"        ║
# ║     (approval takes ~24hrs)                                 ║
# ║  6. Buy SMS credits before sending                          ║
# ║                                                              ║
# ╚══════════════════════════════════════════════════════════════╝

# Server
PORT=3000
NODE_ENV=development
API_BASE_URL=https://api.revolverent.com

# Database (PostgreSQL)
# Option A: Supabase / Render — use connection string
DATABASE_URL=postgresql://postgres:your_password@db.your-ref.supabase.co:5432/postgres
# Option B: Local dev — use individual vars (if DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=revolve_rent
# DB_USER=revolve
# DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRES_IN=30d

# M-Pesa (Safaricom Daraja API)
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
MPESA_SHORTCODE=174379
MPESA_ENVIRONMENT=sandbox
# sandbox: https://sandbox.safaricom.co.ke
# production: https://api.safaricom.co.ke
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CALLBACK_URL=https://api.revolverent.co.ke/api/v1/payments/mpesa/callback
MPESA_TIMEOUT_URL=https://api.revolverent.co.ke/api/v1/payments/mpesa/timeout

# HostPinnacle SMS Gateway
# Auth: uses userid + password (your HostPinnacle portal login credentials)
# API: POST /SMSApi/send with form-data (sendMethod: quick | group | bulkupload)
# Docs: https://smsportal.hostpinnacle.co.ke
HOSTPINNACLE_USER_ID=GERSHON
HOSTPINNACLE_PASSWORD=your_hostpinnacle_password
HOSTPINNACLE_SENDER_ID=REVOLVERENT
HOSTPINNACLE_BASE_URL=https://smsportal.hostpinnacle.co.ke

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Platform Fee (percentage of rent collected)
PLATFORM_FEE_PERCENT=2
